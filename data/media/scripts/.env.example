# Copy to .env in your project root (next to loci.toml).
# Free offline pyttsx3 and free online gTTS need no keys.

# OpenAI TTS (audio.service = "openai")
OPENAI_API_KEY="sk-..."

# Azure Speech (audio.service = "azure")
AZURE_SUBSCRIPTION_KEY="..."
AZURE_SERVICE_REGION="..."

# ElevenLabs (audio.service = "elevenlabs")
ELEVEN_API_KEY="..."
