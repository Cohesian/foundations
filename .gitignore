# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Build / cache
.cache/
dist/
build/
*.egg-info/

# Data / outputs
outputs/
tmp/
temp/

# Local-only notes (rollout plans, PR drafts) — see .changes/README.md
.changes/*
!.changes/README.md

# K-graph renders — video binaries live in a bucket, not in git.
# The k-graph node yamls declare data.media.renders; renders/ mirrors loci paths.
data/media/renders/**/*.mp4
data/media/renders/**/*.mov
data/media/renders/**/*.webm
!data/media/renders/.gitkeep
