# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.nbconvert.ipynb

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Build / cache
.cache/
dist/
build/
*.egg-info/

# Data / outputs
outputs/
tmp/
temp/

# Local-only notes (rollout plans, PR drafts) — see .changes/README.md
.changes/*
!.changes/README.md

# K-graph media — video binaries live in a bucket, not in git.
# The tree/ node yamls keep the format-agnostic locators; media/ mirrors paths only.
media/**/*.mp4
media/**/*.mov
media/**/*.webm
!media/.gitkeep