# K-graph videos — mp4 binaries live in a bucket / on YouTube, not in git.
# Leaf yaml declares media.videos; k-graph.toml routes outgo per infra.
data/media/videos/**/*.mp4
data/media/videos/**/*.mov
data/media/videos/**/*.webm
!data/media/videos/.gitkeep
